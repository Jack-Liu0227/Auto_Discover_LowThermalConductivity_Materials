# ASLK environment template
# Copy this file to `.env` and fill in your real values.

# Default configuration
WORKFLOW_MODEL=deepseek-chat
WORKFLOW_API_KEY=
WORKFLOW_BASE_URL=https://api.deepseek.com/v1

THEORY_UPDATE_MODEL=deepseek-chat
THEORY_UPDATE_API_KEY=
THEORY_UPDATE_BASE_URL=https://api.deepseek.com/v1

TEMPERATURE=0.3

# Materials database
MP_API_KEY=your materials project api

# Optional public endpoint override
# AFLOW_BASE_URL=https://aflowlib.org/API/aflux/
